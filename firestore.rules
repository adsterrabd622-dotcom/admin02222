rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidVideo(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.thumbnail is string && data.thumbnail.size() <= 500 &&
             data.duration is string && data.duration.size() <= 20 &&
             data.description is string && data.description.size() <= 2000 &&
             data.videoUrl is string && data.videoUrl.size() <= 500;
    }

    // Video collection rules
    match /videos/{videoId} {
      allow read: if true; 
      allow create: if isValidVideo(request.resource.data);
      allow update: if isValidVideo(request.resource.data);
      allow delete: if true;
    }
  }
}
